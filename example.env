
# MySQL database settings (used in clinic/settings.py)
MYSQL_DATABASE=clinic_appointment_system
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Gmail SMTP settings (used in clinic/settings.py)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=Clinic Appointment System <your_email@gmail.com>
